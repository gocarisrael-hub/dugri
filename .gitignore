.DS_Store
**/.DS_Store
# macOS drag/clipboard turds
.com.apple.*
**/.com.apple.*

# Local Netlify folder
.netlify

# Node / tests
node_modules/
node_modules
coverage/
test-results/
playwright-report/
.vitest/

# Claude local (worktrees, plans, etc.)
.claude/

# Word-collection local data (server JSON store + e2e throwaway dir)
.e2e-data/
dugri-data.json

# Generated order PDFs (produced on demand by the server; never committed)
server/generated/

# Large local media / working files (keep out of git — GitHub caps files at 100MB)
resources/clips/
*.mov
*.mp4

# Private/reference material kept locally only (payment QR codes, IG screenshots)
resources/payment/
resources/instagram/screenshots/

# but DO track the small web-optimized clips
!site/assets/video/
!site/assets/video/*.mp4

# All local working materials under resources/ are untracked — only resources/canva/
# (the tokenizer's SVG sources) is tracked. Ignore the rest so agents' `git add -A`
# / `git stash -u` can't sweep your working docs (comparison PDF/DOCX, screenshots…).
/resources/*
!/resources/canva/

# Canva source SVGs — LOCAL-ONLY build input (~58MB each), never served. The
# committed site/assets/designs/ outputs are what actually run the site. To
# rebuild: place these sources locally, then `node scripts/tokenize-svg.mjs`.
#  - "full deck": the raw Hebrew, typo-prone Canva exports.
#  - staging: the ASCII-named copies the tokenizer reads (see the script header
#    for the full-deck → staging file mapping).
/resources/canva/full deck/
/resources/canva/staging/

# Agent screenshot / scratch output
/output/
