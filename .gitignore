.DS_Store
**/.DS_Store
# macOS drag/clipboard turds
.com.apple.*
**/.com.apple.*

# Local Netlify folder
.netlify

# Node / tests
node_modules/
coverage/
test-results/
playwright-report/
.vitest/

# Claude local (worktrees, plans, etc.)
.claude/

# Word-collection local data (server JSON store + e2e throwaway dir)
.e2e-data/
dugri-data.json

# Large local media / working files (keep out of git — GitHub caps files at 100MB)
resources/clips/
*.mov
*.mp4

# Private/reference material kept locally only (payment QR codes, IG screenshots)
resources/payment/
resources/instagram/screenshots/

# but DO track the small web-optimized clips
!site/assets/video/
!site/assets/video/*.mp4

# All local working materials under resources/ are untracked — only resources/canva/
# (the tokenizer's SVG sources) is tracked. Ignore the rest so agents' `git add -A`
# / `git stash -u` can't sweep your working docs (comparison PDF/DOCX, screenshots…).
/resources/*
!/resources/canva/
!/resources/canva/**

# Agent screenshot / scratch output
/output/
